---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { SITE } from '../data/site';
import { getSchema } from '../lib/schema';
import type { SchemaContext } from '../lib/schema';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: string;
  publishedTime?: string;
  tags?: string[];
  currentPath?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
  image = SITE.image,
  canonical: canonicalProp,
  type = 'website',
  publishedTime,
  tags = [],
  currentPath = '/',
} = Astro.props;

const canonical = canonicalProp ?? new URL(currentPath, SITE.url).toString();
const pageTitle = title === SITE.title ? SITE.title : `${title} — ${SITE.title}`;

const schemaCtx: SchemaContext = { title, description, canonical, currentPath, type, publishedTime, tags };
const jsonLd = getSchema(schemaCtx);
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />
    <meta name="theme-color" content="#0B1220" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#FFFFFF" media="(prefers-color-scheme: light)" />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, SITE.url).toString()} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE.title} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, SITE.url).toString()} />

    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <title>{pageTitle}</title>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

    <!-- Pagefind will be loaded on the search page -->
  </head>
  <body class="min-h-screen flex flex-col">
    <Header currentPath={currentPath} />

    <main class="flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
