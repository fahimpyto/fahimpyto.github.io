---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
---

<BaseLayout title="Search" description="Search articles and projects on fahimpyto." currentPath="/search">
  <section class="section-padding">
    <div class="container-main">
      <SectionTitle
        title="Search"
        description="Find articles, projects, and more."
      />

      <div class="max-w-2xl mx-auto">
        <div id="search"></div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { PagefindUI } from '@pagefind/default-ui';

  new PagefindUI({
    element: '#search',
    showSubResults: true,
    showImages: false,
    resetStyles: false,
    highlightParam: true,
  });
</script>

<style>
  @import '@pagefind/default-ui/css/ui.css';

  :global(.pagefind-ui__search-input) {
    height: 48px;
    padding: 0 16px;
    border-radius: 8px;
    border: 1px solid var(--color-current-border);
    background: var(--color-current-surface);
    color: var(--color-current-text);
    font-size: 16px;
  }

  :global(.pagefind-ui__search-input:focus) {
    border-color: var(--color-current-primary);
    outline: 2px solid var(--color-current-primary-muted);
  }

  :global(.pagefind-ui__result-title) {
    color: var(--color-current-text);
    font-weight: 600;
  }

  :global(.pagefind-ui__result-excerpt) {
    color: var(--color-current-text-secondary);
  }

  :global(.pagefind-ui__search-clear) {
    color: var(--color-current-text-muted);
  }

  :global(.pagefind-ui__result-tag) {
    background: var(--color-current-primary-muted);
    color: var(--color-current-primary);
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 12px;
  }
</style>
