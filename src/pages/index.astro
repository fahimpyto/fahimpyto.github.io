---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
import ProjectCard from '../components/widgets/ProjectCard.astro';
import BlogCard from '../components/widgets/BlogCard.astro';
import SkillPill from '../components/widgets/SkillPill.astro';
import StatCounter from '../components/widgets/StatCounter.astro';
import CTA from '../components/widgets/CTA.astro';
import { HERO, HOME_SECTIONS, QUICK_STATS } from '../data/site';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const blogPosts = await getCollection('blog');

const featuredProjects = projects
  .filter((p) => p.data.featured)
  .slice(0, 4);

const latestPosts = blogPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

import skillsData from '../data/skills';
---

<BaseLayout currentPath="/">
  <!-- Hero Section -->
  <section class="section-padding min-h-[85vh] flex items-center">
    <div class="container-main">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="animate-fade-in">
          <h1 class="text-5xl sm:text-6xl md:text-7xl font-heading font-bold text-(--color-current-text) tracking-tight leading-[1.1]">
            {HERO.name}
          </h1>
          <p class="text-lg md:text-xl text-(--color-current-primary) font-medium mt-4">
            {HERO.tagline}
          </p>
          <p class="text-base md:text-lg text-(--color-current-text-secondary) mt-4 leading-relaxed max-w-xl">
            {HERO.bio}
          </p>

          <div class="flex flex-wrap gap-3 mt-8">
            <Button href="/projects" size="lg">View Projects</Button>
            <Button href="/articles" variant="secondary" size="lg">Read Articles</Button>
            <Button href="/resume" variant="ghost" size="lg">Download Resume</Button>
          </div>

          <div class="flex items-center gap-4 mt-8">
            <a href="https://github.com/fahimpyto" target="_blank" rel="noopener noreferrer" class="text-(--color-current-text-muted) hover:text-(--color-current-primary) transition-colors" aria-label="GitHub">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
            <a href="https://linkedin.com/in/fahimpyto" target="_blank" rel="noopener noreferrer" class="text-(--color-current-text-muted) hover:text-(--color-current-primary) transition-colors" aria-label="LinkedIn">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
            <a href="https://www.facebook.com/fahimpyto" target="_blank" rel="noopener noreferrer" class="text-(--color-current-text-muted) hover:text-(--color-current-primary) transition-colors" aria-label="Facebook">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <a href="mailto:fahimpyto@email.com" class="text-(--color-current-text-muted) hover:text-(--color-current-primary) transition-colors" aria-label="Email">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="flex justify-center animate-fade-in">
          <div class="relative">
            <div class="w-48 h-48 sm:w-64 sm:h-64 lg:w-80 lg:h-80 rounded-2xl border border-(--color-current-border) bg-(--color-current-surface) overflow-hidden shadow-xl">
              <img
                src="/fa_lkn.png"
                alt="Fahim Ahmed"
                class="w-full h-full object-cover"
                width="320"
                height="320"
                loading="eager"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Current Focus -->
  <section class="section-padding border-t border-(--color-current-border)">
    <div class="container-main">
      <div class="max-w-3xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-widest text-(--color-current-primary) mb-3 text-center">
          Current Focus
        </p>
        <p class="text-lg md:text-xl text-(--color-current-text-secondary) text-center leading-relaxed">
          {HOME_SECTIONS.currentFocus}
        </p>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="section-padding border-t border-(--color-current-border)">
      <div class="container-main">
        <SectionTitle
          title="Featured Projects"
          description="A selection of things I've built."
        />
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {featuredProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              techStack={project.data.techStack}
              githubUrl={project.data.githubUrl}
              pypiUrl={project.data.pypiUrl}
              slug={project.id.replace(/\/index\.mdx$/, '').replace(/\.mdx$/, '')}
              image={project.data.heroImage}
              class="animate-slide-up"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Latest Articles -->
  {latestPosts.length > 0 && (
    <section class="section-padding border-t border-(--color-current-border)">
      <div class="container-main">
        <SectionTitle
          title="Latest Articles"
          description="Thoughts, tutorials, and deep dives."
        />
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {latestPosts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              tags={post.data.tags}
              slug={post.id.replace(/\/index\.mdx$/, '').replace(/\.mdx$/, '')}
              class="animate-slide-up"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Featured Skills -->
  <section class="section-padding border-t border-(--color-current-border)">
    <div class="container-main">
      <SectionTitle
        title="Skills & Expertise"
        description="Technologies and domains I work with."
      />
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {skillsData.map((skillGroup) => (
          <SkillPill
            domain={skillGroup.domain}
            skills={skillGroup.skills}
            color={skillGroup.color}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Achievements / Quick Stats -->
  <section class="section-padding border-t border-(--color-current-border)">
    <div class="container-main">
      <SectionTitle
        title="Achievements"
        description="Milestones and metrics."
      />
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {QUICK_STATS.map((stat) => (
          <StatCounter
            value={stat.value}
            label={stat.label}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA />

</BaseLayout>
