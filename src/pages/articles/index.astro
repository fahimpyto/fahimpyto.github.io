---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import BlogCard from '../../components/widgets/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const publishedPosts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const categories = [...new Set(publishedPosts.map((p) => p.data.category))];
const allTags = [...new Set(publishedPosts.flatMap((p) => p.data.tags))];
---

<BaseLayout title="Articles" description="Thoughts, tutorials, and deep dives on Python, automation, SEO, and more." currentPath="/articles">
  <section class="section-padding">
    <div class="container-main">
      <SectionTitle
        title="Articles"
        description="Thoughts, tutorials, and deep dives."
      />

      {publishedPosts.length > 0 ? (
        <>
          <div class="flex flex-wrap gap-2 mb-8 justify-center">
            {categories.map((cat) => (
              <a
                href={`/articles/category/${cat.toLowerCase()}`}
                class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-medium border border-(--color-current-border) text-(--color-current-text-secondary) hover:border-(--color-current-primary) hover:text-(--color-current-primary) transition-colors"
              >
                {cat}
              </a>
            ))}
          </div>

          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {publishedPosts.map((post) => (
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                category={post.data.category}
                tags={post.data.tags}
                slug={post.id.replace(/\/index\.mdx$/, '').replace(/\.mdx$/, '')}
              />
            ))}
          </div>
        </>
      ) : (
        <div class="text-center py-20">
          <p class="text-(--color-current-text-secondary) text-lg mb-2">
            No articles yet.
          </p>
          <p class="text-(--color-current-text-muted) text-sm">
            Articles will appear here once published.
          </p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
