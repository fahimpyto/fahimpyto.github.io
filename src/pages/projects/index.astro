---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import ProjectCard from '../../components/widgets/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Projects" description="A collection of projects I've built." currentPath="/projects">
  <section class="section-padding">
    <div class="container-main">
      <SectionTitle
        title="Projects"
        description="Things I've built and contributed to."
      />

      {sorted.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {sorted.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              techStack={project.data.techStack}
              githubUrl={project.data.githubUrl}
              pypiUrl={project.data.pypiUrl}
              slug={project.id.replace(/\/index\.mdx$/, '').replace(/\.mdx$/, '')}
              image={project.data.heroImage}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <p class="text-(--color-current-text-secondary) text-lg">
            Projects coming soon.
          </p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
