---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/widgets/Breadcrumbs.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import CTA from '../../components/widgets/CTA.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => {
    const slug = project.id.replace(/\/index\.mdx$/, '').replace(/\.mdx$/, '');
    return {
      params: { slug },
      props: { project, slug },
    };
  });
}

const { project, slug } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
  currentPath={`/projects/${slug}`}
  publishedTime={project.data.pubDate.toISOString()}
  tags={project.data.techStack}
  type="article"
>
  <section class="section-padding">
    <div class="container-main">
      <Breadcrumbs
        items={[
          { label: 'Home', href: '/' },
          { label: 'Projects', href: '/projects' },
          { label: project.data.title },
        ]}
      />

      <article>
        <header class="mb-12">
          <h1 class="text-4xl md:text-5xl font-heading font-bold text-(--color-current-text) tracking-tight mb-4">
            {project.data.title}
          </h1>
          <p class="text-lg text-(--color-current-text-secondary) mb-6 max-w-2xl">
            {project.data.description}
          </p>

          <div class="flex flex-wrap gap-2 mb-6">
            {project.data.techStack.map((tech) => (
              <Badge>{tech}</Badge>
            ))}
          </div>

          <div class="flex flex-wrap gap-3">
            {project.data.githubUrl && (
              <Button href={project.data.githubUrl} variant="secondary" external>
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                GitHub Repository
              </Button>
            )}
            {project.data.liveUrl && (
              <Button href={project.data.liveUrl} variant="secondary" external>
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                  <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                </svg>
                Live Demo
              </Button>
            )}
            {project.data.pypiUrl && (
              <Button href={project.data.pypiUrl} variant="secondary" external>
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2L2 7v10l10 5 10-5V7l-10-5zm0 2.5l7.5 3.75-7.5 3.75-7.5-3.75L12 4.5zM3.5 16.5V8.5l7.5 3.75v8l-7.5-3.75zm17 0L13 20.25v-8l7.5-3.75v8z"/>
                </svg>
                PyPI Package
              </Button>
            )}
          </div>
        </header>

        <div class="prose max-w-none">
          <Content />
        </div>
      </article>
    </div>
  </section>

  <CTA title="Interested in this project?" description="Have questions or want to collaborate? Let's talk!" buttonLabel="Get in Touch →" buttonHref="/contact" />
</BaseLayout>
