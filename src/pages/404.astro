---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout title="Page Not Found">
  <section class="section-padding min-h-[60vh] flex items-center">
    <div class="container-main text-center">
      <h1 class="text-8xl md:text-9xl font-heading font-bold text-(--color-current-primary) tracking-tight mb-4">
        404
      </h1>
      <p class="text-xl text-(--color-current-text-secondary) mb-2">
        Page not found
      </p>
      <p class="text-(--color-current-text-muted) mb-8 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex justify-center gap-3">
        <Button href="/">Go Home</Button>
        <Button href="/articles" variant="secondary">Browse Articles</Button>
      </div>
    </div>
  </section>
</BaseLayout>
