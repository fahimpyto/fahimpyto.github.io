---
export interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  external?: boolean;
  class?: string;
}

const { href, variant = 'primary', size = 'md', external = false } = Astro.props;

const baseStyles = 'inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 cursor-pointer no-underline';

const variants: Record<string, string> = {
  primary: 'bg-(--color-current-primary) text-white hover:bg-(--color-current-primary-hover) active:scale-[0.98]',
  secondary: 'border border-(--color-current-border) bg-(--color-current-surface) text-(--color-current-text) hover:border-(--color-current-primary) hover:text-(--color-current-primary)',
  ghost: 'text-(--color-current-text-secondary) hover:text-(--color-current-primary) hover:bg-(--color-current-surface)',
};

const sizes: Record<string, string> = {
  sm: 'h-9 px-4 text-sm gap-1.5',
  md: 'h-11 px-6 text-sm gap-2',
  lg: 'h-13 px-8 text-base gap-2.5',
};

const classes = `${baseStyles} ${variants[variant]} ${sizes[size]} ${Astro.props.class || ''}`;
---

{
  href ? (
    <a href={href} class={classes} {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
      <slot />
    </a>
  ) : (
    <button class={classes} type="button">
      <slot />
    </button>
  )
}
