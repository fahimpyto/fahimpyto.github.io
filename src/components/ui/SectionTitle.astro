---
export interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { title, description, eyebrow, align = 'center' } = Astro.props;
---

<div class={`mb-12 ${align === 'center' ? 'text-center' : ''} ${Astro.props.class || ''}`}>
  {eyebrow && (
    <p class="text-xs font-semibold uppercase tracking-widest text-(--color-current-primary) mb-3">
      {eyebrow}
    </p>
  )}
  <h2 class="text-3xl md:text-4xl font-heading font-bold text-(--color-current-text) tracking-tight">
    {title}
  </h2>
  {description && (
    <p class="mt-3 text-(--color-current-text-secondary) text-lg max-w-2xl mx-auto">
      {description}
    </p>
  )}
</div>
