---
import Button from '../ui/Button.astro';
import SectionTitle from '../ui/SectionTitle.astro';

export interface Props {
  title?: string;
  description?: string;
  buttonLabel?: string;
  buttonHref?: string;
  class?: string;
}

const {
  title = "Let's Work Together",
  description = "I'm always open to new projects, collaborations, and opportunities. Feel free to reach out!",
  buttonLabel = 'Get in Touch →',
  buttonHref = '/contact',
} = Astro.props;
---

<section class={`section-padding ${Astro.props.class || ''}`}>
  <div class="container-narrow text-center">
    <SectionTitle
      title={title}
      description={description}
      align="center"
    />
    <div class="mt-8">
      <Button href={buttonHref} size="lg">{buttonLabel}</Button>
    </div>
  </div>
</section>
