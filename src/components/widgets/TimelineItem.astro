---
import Badge from '../ui/Badge.astro';

export interface Props {
  title: string;
  date: string;
  description: string;
  tags?: string[];
  category?: string;
  class?: string;
}

const { title, date, description, tags = [], category } = Astro.props;
---

<div class="relative pl-8 pb-8 border-l-2 border-(--color-current-border) last:border-transparent last:pb-0">
  <div class="absolute left-0 top-0 w-3 h-3 -translate-x-[7px] rounded-full bg-(--color-current-primary) border-2 border-(--color-current-bg)"></div>

  <div class="mb-1 flex items-center gap-3">
    <span class="text-xs font-semibold text-(--color-current-primary)">{date}</span>
    {category && <Badge>{category}</Badge>}
  </div>

  <h3 class="text-base font-heading font-semibold text-(--color-current-text) mb-1">
    {title}
  </h3>
  <p class="text-sm text-(--color-current-text-secondary) leading-relaxed">
    {description}
  </p>

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-2">
      {tags.map((tag) => (
        <span class="text-xs text-(--color-current-text-muted) bg-(--color-current-bg) px-2 py-0.5 rounded border border-(--color-current-border)">
          {tag}
        </span>
      ))}
    </div>
  )}
</div>
