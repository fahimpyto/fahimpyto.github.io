---
import Badge from '../ui/Badge.astro';

export interface Props {
  title: string;
  description: string;
  techStack: string[];
  githubUrl?: string;
  pypiUrl?: string;
  liveUrl?: string;
  slug: string;
  class?: string;
  image?: string;
}

const { title, description, techStack, githubUrl, pypiUrl, liveUrl, slug, image } = Astro.props;
---

<div
  class={`group card card-hover relative overflow-hidden flex flex-col h-full ${Astro.props.class || ''}`}
>
  <a
    href={`/projects/${slug}`}
    class="absolute inset-0 z-0"
    aria-label={`View ${title}`}
  >
    <span class="sr-only">View {title}</span>
  </a>
  {image && (
    <div class="bg-(--color-current-bg) flex items-center justify-center overflow-hidden" style="height: 240px;">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-contain p-4"
        loading="lazy"
      />
    </div>
  )}
  <div class="p-4 flex flex-col flex-1 gap-2.5 relative z-10">
    <h3 class="text-base font-heading font-semibold text-(--color-current-text)">
      {title}
    </h3>
    <p class="text-xs text-(--color-current-text-secondary) leading-relaxed">
      {description}
    </p>

    <div class="flex flex-wrap gap-1.5">
      {techStack.map((tech) => (
        <Badge>{tech}</Badge>
      ))}
    </div>

    <div class="flex items-center gap-3 text-xs font-medium pt-3 mt-1 border-t border-(--color-current-border/50)">
      {githubUrl && (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-(--color-current-text-secondary) hover:text-(--color-current-primary) transition-colors relative z-20"
          onclick="event.stopPropagation()"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
      )}
      {liveUrl && (
        <a
          href={liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-(--color-current-text-secondary) hover:text-(--color-current-primary) transition-colors relative z-20"
          onclick="event.stopPropagation()"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
          </svg>
          Live
        </a>
      )}
      {pypiUrl && (
        <a
          href={pypiUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-(--color-current-text-secondary) hover:text-(--color-current-primary) transition-colors relative z-20"
          onclick="event.stopPropagation()"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2L2 7v10l10 5 10-5V7l-10-5zm0 2.5l7.5 3.75-7.5 3.75-7.5-3.75L12 4.5zM3.5 16.5V8.5l7.5 3.75v8l-7.5-3.75zm17 0L13 20.25v-8l7.5-3.75v8z"/>
          </svg>
          PyPI
        </a>
      )}
    </div>
  </div>
</div>
